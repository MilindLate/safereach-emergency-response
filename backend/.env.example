# SafeReach Backend — Environment Variables
# Copy this to .env.local and fill in your values

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
FRONTEND_BASE_URL=http://localhost:3000
ALLOWED_HOSTS=["*"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://safereach:safereach@localhost:5432/safereach
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_DEVICE_TOKEN_EXPIRE_DAYS=365

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=safereach-media

# ── Twilio SMS ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
EMERGENCY_NUMBER=112

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Firebase FCM ─────────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── Bhashini (multilingual AI) ───────────────────────────────────────────────
BHASHINI_API_KEY=your-bhashini-api-key
BHASHINI_USER_ID=your-bhashini-user-id

# ── AI Models ─────────────────────────────────────────────────────────────────
SEVERITY_CNN_MODEL_PATH=app/ai/models/severity_cnn.pt
HOTSPOT_MODEL_PATH=app/ai/models/hotspot_xgboost.pkl
CNN_INFERENCE_TIMEOUT_S=2.0

# ── OSRM ─────────────────────────────────────────────────────────────────────
OSRM_BASE_URL=http://localhost:5000
ROUTE_REFRESH_INTERVAL_S=30

# ── Feature flags ─────────────────────────────────────────────────────────────
AUTO_DISPATCH_CRITICAL_TIMEOUT_S=30
HOSPITAL_PREALERT_MINUTES_BEFORE=10
HOTSPOT_REFRESH_HOURS=6
